meta {
  name: Deletar Produto
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/admin
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "id": {{createdProductId}}
  }
}

tests {
  test("deve deletar produto com sucesso", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.equal(true);
  });
}
