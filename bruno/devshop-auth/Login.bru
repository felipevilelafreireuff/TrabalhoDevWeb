meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{email}}",
    "senha": "{{senha}}"
  }
}

tests {
  test("deve autenticar com sucesso", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.equal(true);
    expect(res.body.usuario.email).to.equal(bru.getEnvVar("email"));
  });
}
